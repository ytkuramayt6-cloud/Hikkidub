# Скопируйте в .env на сервере: cp env.example .env && nano .env
# Файл .env в git не коммитится — см. .gitignore

# Обязательно смените в продакшене
DJANGO_SECRET_KEY=замените-на-случайную-строку-50-символов
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Если сайт по HTTPS за прокси — укажите полные URL (через запятую)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Должны совпадать с блоком db в docker-compose (или переопределите там)
POSTGRES_USER=hikkidub
POSTGRES_PASSWORD=сильный-пароль
POSTGRES_DB=hikkidub

# Порт на хосте (nginx)
HTTP_PORT=80
